  <appSettings>
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <add key="enableSimpleMembership" value="false" />
    <add key="autoFormsAuthentication" value="false" />
    <add key="EnableCreationOfDummyCustomers" value="false" />
    <!-- Email Configuration -->
    <add key="Intelledata.Common.Email.Host" value="barbados.internal.blx.com" />
    <add key="Intelledata.Common.Email.Port" value="25" />
    <!-- Leave blank to use Integrated Authentication -->
    <add key="Intelledata.Common.Email.Username" value="" />
    <add key="Intelledata.Common.Email.Password" value="" />
    <add key="log4net.Internal.Debug" value="true"/>
